# Backend Environment Variables
# Copy this file to .env and fill in the values

# Database provider: "sqlite" for local dev, "postgresql" for production (Render)
DATABASE_PROVIDER="postgresql"

# PostgreSQL connection string (provided by Render automatically in production)
# For local dev use: DATABASE_URL="file:./dev.db" with DATABASE_PROVIDER="sqlite"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# JWT secret key - use a long random string in production
JWT_SECRET="your_super_secret_jwt_key_here"

# Server port
PORT=5000
